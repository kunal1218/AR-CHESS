PORT=8080

# Point these at your Google Cloud SQL Postgres instance.
DATABASE_URL=postgresql://postgres:password@your-cloudsql-postgres-host:5432/archess
PGHOST=your-cloudsql-postgres-host
PGPORT=5432
PGDATABASE=archess
PGUSER=postgres
PGPASSWORD=password

# Gemini Live backend-only credentials/config
GEMINI_API_KEY=your_gemini_api_key
# Gemini 3 models do not support the Live API. Keep the Live session on a supported Live model.
GEMINI_LIVE_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_LIVE_TEMPERATURE=0.95
GEMINI_LIVE_TOP_P=0.9
GEMINI_LIVE_TOP_K=32
GEMINI_LIVE_MAX_OUTPUT_TOKENS=64
GEMINI_LIVE_TURN_TIMEOUT_SECONDS=12
