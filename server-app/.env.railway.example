PORT=8080

# Railway Postgres may inject one or more of these automatically.
DATABASE_PRIVATE_URL=postgresql://postgres:password@your-railway-postgres-host:5432/railway
DATABASE_URL=postgresql://postgres:password@your-railway-postgres-host:5432/railway
PGHOST=your-railway-postgres-host
PGPORT=5432
PGDATABASE=railway
PGUSER=postgres
PGPASSWORD=password

# Optional split variables if you are not using DATABASE_URL directly.
POSTGRES_HOST=your-railway-postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=railway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Gemini Live backend-only credentials/config
GEMINI_API_KEY=your_gemini_api_key
# Gemini 3 models do not support the Live API. Keep the Live session on a supported Live model.
GEMINI_LIVE_MODEL=models/gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_LIVE_TEMPERATURE=0.95
GEMINI_LIVE_TOP_P=0.9
GEMINI_LIVE_TOP_K=32
GEMINI_LIVE_MAX_OUTPUT_TOKENS=64
GEMINI_LIVE_TURN_TIMEOUT_SECONDS=12
